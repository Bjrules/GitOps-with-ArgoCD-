pipeline{
    agent any

    tools {
        //jdk 'jdk17'   // name must match what you configured in Manage Jenkins → Tools
        maven 'maven3' // name must match what you configured in Manage Jenkins → Tools
    }
    // Define environment variables, 
environment {
SCANNER_HOME = tool 'sonar-scanner'
JAVA_HOME = '/usr/lib/jvm/java-17-openjdk-amd64'
PATH = "${JAVA_HOME}/bin:${env.PATH}"
}
parameters{
    string(name: 'DOCKER_TAG', defaultValue:'latest', description: 'Docker tag')
}
    stages{
             // Stage to clean the workspace
        stage('Clean Workspace') {
            steps {
                    cleanWs() // Clean up previous files
                }
        }
        stage('Git Checkout'){
            steps {
                git branch: 'CI-main', credentialsId: 'github-cred', url: 'https://github.com/Bjrules/GitOps-with-ArgoCD-.git'
            }
        }

        stage('compile'){
            steps {
                sh "mvn compile"
            }
        }
        stage('test'){
            steps {
                sh "mvn test -DskipTests=true" // This enable jenkins to skip this testing stage
            }
        }

        stage('File System Scan'){
            steps {
              sh "trivy fs --format table -o fs.html ." // Scan filesystem and save report as HTML
            }
        }
         stage('SonarQube Analysis'){
            steps {
                // kindly remove credentialID as parameter in withSonarQubeEnv
               withSonarQubeEnv('Sonar-Server') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=bankapp -Dsonar.projectKey=bankapp \
-Dsonar.java.binaries=target '''
                }
            }
        }

         stage('Build and Publish to Nexus'){
            steps {
            withMaven(globalMavenSettingsConfig: 'Banjo-maven-Settings', jdk:'jdk17', maven: 'maven3', traceability: true) {
                
                //sh 'mvn clean package -DskipTests'
                // 'mvn deploy -DskipTests=true' skips test because there is a known bug already in the source code
               sh "mvn deploy -DskipTests=true"
               }
            }
        }

        stage('Docker Build and Tag'){
            steps {
                script{
               withDockerRegistry(credentialsId: 'Docker-Login') {
                sh "docker build -t bjrules/bankapp:${params.DOCKER_TAG} . "
               }
        }
            }
        }

        // stage('Docker Image Scan'){
        //     steps {
        //       sh "trivy image --format table -o dimage.html bjrules/bankapp:${params.DOCKER_TAG} " // Scan Docker Image and save report as HTML
        //     }
        // }
            
        stage('Docker Push'){
            steps {
                script{
               withDockerRegistry(credentialsId: 'Docker-Login') {
                sh "docker push bjrules/bankapp:${params.DOCKER_TAG}"
               }
        }
            }
        }

        // Update the image tag in the YAML manifest in another repository
        stage('Update YAML Manifest in Other Repo'){
              steps {
                script {
                    withCredentials([gitUsernamePassword(credentialsId: 'github-cred', gitToolName: 'Default')]) {
                        sh '''
            # Clone the repo containing the Kubernetes deployment manifest
            git clone -b CD-GitOps https://github.com/Bjrules/GitOps-with-ArgoCD-.git
            cd GitOps-with-ArgoCD-
            # Check if the bankapp-ds.yml file exists
            ls -l bankapp
            # Update the Docker image tag in the YAML file
            sed -i "s|image: bjrules/bankapp:.*|image: bjrules/bankapp:${DOCKER_TAG}|" $(pwd)/bankapp/bankapp-ds.yml
            '''
            // Confirm the change in the updated YAML file
            sh '''
            echo "Updated YAML file contents:"
            cat GitOps-with-ArgoCD-/bankapp/bankapp-ds.yml
            '''
            // Configure Git for the commit
            sh '''
            cd GitOps-with-ArgoCD-
            git config user.email "rulesxx@gmail.com"
            git config user.name "Bjrules"
            '''
            // Commit and push the changes back to the repository
            sh '''
            cd GitOps-with-ArgoCD-
            ls
            git add bankapp/bankapp-ds.yml
            git commit -m "Update image tag to ${DOCKER_TAG}"
            git push
            '''
            }
        }
    }
    
}


    }
}